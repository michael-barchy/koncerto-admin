{
    "name": "michael-barchy/koncerto-admin",
    "type": "library",
    "version": "0.0.1",
    "minimum-stability": "alpha",
    "autoload": {
        "psr-4": {
            "KoncertoAdmin\\": "./src"
        }
    },
    "config": {
        "platform": {
            "php": "5.3"
        }
    },
    "repositories": {
        "koncerto": {
            "type": "vcs",
            "no-api": true,
            "url": "https://github.com/michael-barchy/koncerto"
        }
    },
    "require": {
        "michael-barchy/koncerto": "dev-main",
        "tinybutstrong/tinybutstrong": "^3.15"
    }
}
